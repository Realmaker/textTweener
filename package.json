{
  "name": "texttweener",
  "version": "1.0.0",
  "description": "Animate text transitions by morphing individual letters to their new positions",
  "author": "Michael Rademacher <info@realmaker.de>",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0",
    "happy-dom": "^16.6.0"
  },
  "keywords": [
    "text",
    "animation",
    "transition",
    "morph",
    "tween",
    "letters",
    "typography"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/realmaker/texttweener"
  },
  "homepage": "https://realmaker.de/texttweener"
}
